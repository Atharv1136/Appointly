# =============================================================================
# Environment variables for LOCAL development
# =============================================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# On Lovable (cloud), these are injected automatically from the Secrets manager
# and the .env file is NOT used. This file is only for running the app locally.
# =============================================================================

# --- Database (Postgres connection string) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@yourdomain.com

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Lovable AI Gateway (only needed if using AI features locally) ---
LOVABLE_API_KEY=
